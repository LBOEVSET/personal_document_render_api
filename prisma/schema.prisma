generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ContentType {
  IMAGE
  VIDEO
  PDF
  COVER
}

enum Department {
  INMATE
  LEGAL
  PR
}

model MainMenu {
  id     String @id
  title  String
  icon   String
  href   String

  createdAt DateTime @default(now())
}

model ContentItem {
  id    String @id
  title String

  type ContentType

  link  String?
  file  String?
  cover String?

  department Department?

  legalId       String?

  prId       String?

  legal      LegalMenu?           @relation(fields: [legalId], references: [id])

  pr      PRPracticeMenu?         @relation(fields: [prId], references: [id])

  createdAt DateTime @default(now())
}

model LegalMenu {
  id        String   @id
  title     String
  order     Int

  contentItems ContentItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PRPracticeMenu {
  id        String   @id
  title     String
  order     Int

  contentItems ContentItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InmateProfile {
  id           String @id
  userId       String @unique
  name         String
  status       String
  cases        Int
  caseType     String
  sentence     String
  startDate    DateTime
  transferFrom String
  releaseDate  DateTime
  progressStep Int

  user User @relation(fields: [userId], references: [id])

  detail InmateDetail?
  @@index([userId])
}

model InmateDetail {
  id        String @id
  age       String
  nationality String
  religion  String
  holdType  String
  holdAgency String

  inmateId String @unique
  inmate   InmateProfile @relation(fields: [inmateId], references: [id])
}

model User {
  id              String          @id @default(uuid())
  username        String          @unique
  passwordHash    String?
  role            UserRole        @default(INMATE)
  name            String
  profileImage    String?
  accessToken     String?
  refreshToken    String?
  status          Int             @default(1)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @default(now()) @updatedAt

  inmateProfile   InmateProfile?

  @@index([status])
}

enum UserRole {
  INMATE
  ADMIN
}
